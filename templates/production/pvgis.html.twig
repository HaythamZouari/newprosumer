<form class="production" id="pvgisForm" action="{{ path('pvgis',{'id':project.id}) }}"  enctype="multipart/form-data">
    <div class="row">
        <div class="col">
                    <input type="hidden" name="raddatabase" value="PVGIS-CMSAF"/>
            <div id="sschamp1">
                <div class="form-group">
                    <label class="form-control-label required">Sous-Champ 1</label>
                </div>        
                <div class="form-group">
                    <label class="form-control-label required">Fixation des modules PV:</label> <button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir la méthode d'implantation des modules PV">
                            ?
                        </button>  
                </div>
                
                 <select name="trackingtype" class="form-control" id="tracking">
                    <option value=0>Fixe</option>
                    <option value=5>Suiveur N/S</option>
                    <option value=3>Suiveur E/O</option>
                    <option value=2>Suiveur double axes</option>
                </select>
                <div class="form-group">
                    <label class="form-control-label required" for="angle" >Inclinaison des modules [°]</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir l'angle que fait la structure des modules PV par rapport à l'horizontale [0;90]">
                            ?
                        </button>  
                    <input type="number" step="0.01" class="form-control" min="0" max="90" name="angle" id="angle" value="0">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="aspect" >Azimuth [°]</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir l'angle que fait la structure des modules PV par rapport au plein sud [-180;+180]">
                            ?
                        </button>  
                    <input type="number" class="form-control" step="1" min="-180" max="180" value="0" name="aspect" id="aspect">
                </div>
                <input name="technologies" id="pvtechchoice"  value="crystSi" type="hidden">
                <div class="form-group">
                    <label class="form-control-label required" for="peakpower" >Puissance crête[kWc]</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir La puissance de la centrale à simuler">
                            ?
                        </button>  
                    <input type="number" class="form-control" step="0.1" min="1" value="0" name="peakpower" id="peakpower">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="loss" >Pertes [%]</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le taux de pertes entre la sortie du champ PV et le PDL ( poste de livraison) ">
                            ?
                        </button>  
                    <input type="number" class="form-control" step="0.1" min="0" max="80" value=14  name="loss" id="loss">
                </div>
                 <div class="form-group">
                    <label class="form-control-label required" for="">Dégradation des performances des modules PV (%)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir la dégradation annuelle des performances des modules photovoltaiques (Cette valeur est définie généralement à 0.5%)">
                            ?
                        </button>  
                    <input type="number" name="degradation" id="degradation" value="0.5" min="0" class="form-control">
                </div>
                
                <div class="text-center">
                    <button type="button" onclick="add_sous_champ2()" class="btn-secondary btn">Ajouter sous-champ</button><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Ajouter un autre champ PV avec une Fixation différente ou une inclinaison et azimut différents">
                            ?
                        </button>      
                </div><br>
            </div>   
            <div id="sschamp2">
                <div class="form-group">
                    <label class="form-control-label required">Sous-Champ 2</label>
                </div>
                    <div class="form-group">
                    <label class="form-control-label required">Type d'integration:</label>
                </div>
                <div class="form-group">
                    <label class="form-control-label required">Fixe</label>
                    <input style="margin-right: 5px" type="radio" checked="checked" name="trackingtype2"  value="0" onclick="fixe()">
                    <label class="form-control-label required">Axe Vertical</label>
                    <input style="margin-right: 5px" type="radio"  name="trackingtype2"  value=3 onclick="vAx()">
                    <label style="margin-right: 5px" class="form-control-label required">Axe Incline</label>
                    <input style="margin-right: 5px" type="radio"  name="trackingtype2"  value=5 onclick="iAx()">
                    <label style="margin-right: 5px" class="form-control-label required">Double Axe</label>
                    <input style="margin-right: 5px" type="radio"  name="trackingtype2"  value=2 onclick="dAx()">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="angle2" >Inclinaison [°]</label>
                    <input type="number" step="0.01" class="form-control" min="0" max="90" name="angle2" id="angle2" value="0">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="aspect2" >Azimuth [°]</label>
                    <input type="number" class="form-control" step="0.01" min="-180" max="180" value="0" name="aspect2" id="aspect2">
                </div>
                <input name="technologies" id="pvtechchoice"  value="crystSi" type="hidden">
                <div class="form-group">
                    <label class="form-control-label required" for="peakpower2" >Puissance crete[kWc]</label>
                    <input type="number" class="form-control" step="1" min="0" value="0" name="peakpower2" id="peakpower2">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="loss2" >Pertes [%]</label>
                    <input type="number" class="form-control" step="0.01" min="0" value=14  name="loss2" id="loss2">
                </div>
                <div class="text-center">
                <button type="button" onclick="add_sous_champ3()" class="btn-secondary btn">Ajouter sous-champ</button>
                </div> <br>
            </div>
            <div id="sschamp3">
                <div class="form-group">
                    <label class="form-control-label required">Sous-Champ 3</label>
                </div>
                    <div class="form-group">
                    <label class="form-control-label required">Type d'integration:</label>
                </div>
                <div class="form-group">
                    <label class="form-control-label required">Fixe</label>
                    <input style="margin-right: 5px" type="radio" checked="checked" name="trackingtype3"  value="0" onclick="fixe()">
                    <label class="form-control-label required">Axe Vertical</label>
                    <input style="margin-right: 5px" type="radio"  name="trackingtype3"  value=3 onclick="vAx()">
                    <label style="margin-right: 5px" class="form-control-label required3">Axe Incline</label>
                    <input style="margin-right: 5px" type="radio"  name="trackingtype3"  value=5 onclick="iAx()">
                    <label style="margin-right: 5px" class="form-control-label required">Double Axe</label>
                    <input style="margin-right: 5px" type="radio"  name="trackingtype3"  value=2 onclick="dAx()">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="angle3" >Inclinaison [°]</label>
                    <input type="number" step="1" class="form-control" min="0" max="90" name="angle3" id="angle3" value="0">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="aspect3" >Azimuth [°]</label>
                    <input type="number" class="form-control" step="1" min="-180" max="180" value="0" name="aspect3" id="aspect3">
                </div>
                <input name="technologies" id="pvtechchoice"  value="crystSi" type="hidden">
                <div class="form-group">
                    <label class="form-control-label required" for="peakpower3" >Puissance crete[kWc]</label>
                    <input type="number" class="form-control" step="1" min="0" value="0" name="peakpower3" id="peakpower3">
                </div>
                <div class="form-group">
                    <label class="form-control-label required" for="loss3" >Pertes [%]</label>
                    <input type="number" class="form-control" step="0.1" min="0" value=14  name="loss3" id="loss3">
                </div>
                
                
            </div>
           

            
        </div>
       
    </div>
     <div class="text-center">
             <button type="button" onclick="pvgisSubmit()" class="btn-secondary btn"><span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" id="loadinggis" style="display:none"></span>Valider</button>
    </div>
    
</form>

<script>
        $(function () {
        $('[data-toggle="popover"]').popover()
        })

    function add_sous_champ2(){
            $('#sschamp2').show('active');
            $('#sschamp1').hide('active');
           
            
    }

    function add_sous_champ3(){
            $('#sschamp3').show('active');
            $('#sschamp2').hide('active');
            $('#sschamp1').hide('active');
           
            
    }

    function fixe(){
        $('#angle').prop('disabled',false);

        $('#aspect').prop('disabled',false);
    }
    function vAx() {
        $('#angle').prop('disabled',false);
        $('#aspect').prop('disabled',true);

    }
    function dAx() {
        $('#angle').prop('disabled',true);
        $('#aspect').prop('disabled',true);

    }
    function iAx() {
        $('#angle').prop('disabled',true);
        $('#aspect').prop('disabled',false);

    }

    function pvgisSubmit() {
        {% if not app.user %}
        window.location.replace('{{ path('security_login') }}');
        {% else %}
         $('#loadinggis').show();
            var data = $('#pvgisForm').serialize();
            var url = $('#pvgisForm').attr('action');
            console.log(data);
            data=data+'&lon='+$('#lon').val()+'&lat='+$('#lat').val();
        var url = $('#pvgisForm').attr('action');
        $.ajax({
                url: url,
                type : 'POST',
                data : data,
                dataType: 'json',
                cache: false,
                success: function (response) {
                    /*
                    for (let i = 0; i < response.data.length ; i++) {
                        dates =new Date(response.data[i][0]*1000);
                        dates.setHours(dates.getHours()-1);
                        response.data[i][0]=dates;
                    }
                    */
                    for (let i = 0; i < response.data2.length ; i++) {
                        dates =new Date(response.data2[i][0]*1000);
                        dates.setHours(dates.getHours()-1);
                        response.data2[i][0]=dates;
                    }
                    console.log(response.period);
                    console.log(response.data);
                    console.log("produc2");
                    console.log(response.newprod);
                    console.log(response.data2);
                    console.log(response.array);
                     console.log("con");
                    console.log(response.con);
                    console.log("pro");
                     console.log(response.pro);
                      console.log(response.aut);
                       console.log(response.ced);
                        console.log(response.imp);

                     $('#successprod').show();
                      $('#loadinggis').hide();
                      $('#errorprod').hide();
                    document.getElementById('prodavancer').removeAttribute('disabled');
                   
                    

                },
                error: function (response) {
                    $('#errorprod').show();
                     $('#loadinggis').hide();
                      $('#successprod').hide();

                }
            });
            /*
            $.get( url ,data,function (dat) {
               console.log(dat);
            });
             */
            return false;
        {% endif %}
    };

   
</script>
