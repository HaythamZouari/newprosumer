<div class="row align-content-center">
    <div class="col-xl-12 mb-4 mb-xl-12" >
        <div class="row align-content-center">
            <div class="col-xl-3 col-lg-6">
            </div>
            <div class="col-xl-3 col-lg-6">
                <div class="card card-stats mb-4 mb-xl-0">
                    <button  class="btn btn-lg" type="button" data-toggle="modal" data-target="#charts" >Graphiques</button>
                </div>
            </div>
            <div class="col-xl-3 col-lg-6">
                <div class="card card-stats mb-4 mb-xl-0">
                    <button  class="btn btn-lg" type="button" data-toggle="modal" data-target="#myModal" id="tableaus" >Tableau</button>
                </div>
            </div>
            <div class="col-xl-3 col-lg-6">
            </div>
        </div>
    </div>
    <div class="col-xl-12 mb-4 mb-xl-0 align-content-center" >
        <div class="card">
            <div class="card-body">
                <h4 class="text-primary">Récapitulatif énergétique</h4>
                <div class="table">
                    <table class="table align-items-center table-bordered ">
                        <thead class="thead-light">
                        </thead>
                        <tbody>
                        <tr>
                            <td>Puissance</td>
                            {% if project.pvgis != null %}
                                <td >{{ project.pvgis.peakpower }}</td>
                            {% elseif project.csvprod != null %}
                                <td >{{ project.csvprod.Puissence }}</td>
                            {% endif %}
                            <td>kWc</td>
                        </tr>
                        <tr id="prod25">
                            <td>Production PV 25 ans</td>
                        </tr>
                        <tr id="t_autoc">
                            <td>Taux d’autoconsommation</td>
                        </tr>
                        <tr id="t_couv">
                            <td>Taux de couverture :</td>
                        </tr>
                        <tr id="t_cd">
                            <td>Taux de l’énergie cédée :</td>
                        </tr>
                        <tr id="productible">
                            <td>Productible :</td>
                        </tr>
                        </tbody>
                    </table>
                </div>
                <h4 class="text-primary">Récapitulatif financier</h4>
                <div class="table">
                    <table class="table align-items-center table-bordered ">
                        <thead class="thead-light">
                        </thead>
                        <tbody>
                        <tr>
                            {% if project.finance != null %}
                            <td>CAPEX</td>
                            <td >{{ project.finance.capex }}</td>
                            <td>DT</td>
                        </tr>
                        <tr>
                            <td>Subvention</td>
                            <td>{{ project.finance.subvention |number_format(0, '.', ' ')}}</td>
                            <td>%</td>
                        </tr>
                        <tr>
                            <td>O&M </td>
                            <td>{{ project.finance.opex }}</td>
                            <td>%</td>
                        </tr>
                        <tr>
                            <td>Annuite :</td>
                            <td>{{ project.finance.annuite|number_format(3, '.', ' ') }}</td>
                            <td>DT</td>
                        </tr>
                        <tr  id="f_r">
                            <td>Facture de regularisation :</td>
                        </tr>
                        <tr id="coutproj">
                            <td>Cout du projet sur 25 ans :</td>
                        </tr>
                        <tr>
                            <td>VAN sur 25 ans :</td>
                            <td>{{ project.finance.van|number_format(3, '.', ' ') }}</td>
                            <td>DT</td>
                        </tr>
                        <tr id="lcoe">
                            <td>LCOE sur 25 ans :</td>
                        </tr>
                        <tr>
                            <td>TRI sur les capitaux propres :</td>
                            <td>{{ project.finance.Tricapitaux|number_format(2, '.', ' ') }}</td>
                            <td>%</td>
                        </tr>
                        <tr>
                            <td>TRI du projet :</td>
                            <td>{{ project.finance.tri25|number_format(2, '.', ' ') }}</td>
                            <td>%</td>
                        </tr>
                        {% endif %}
                        <tr>
                        </tr>
                        </tbody>
                    </table>
                </div>
                <br>
            </div>

        </div>
    </div>
</div>
