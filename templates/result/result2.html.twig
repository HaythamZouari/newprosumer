        function res (url) {
            if (presence_data===0){
                presence_data=1;
                $.ajax({
                    url: "{{ path('project_results',{ 'id':project.id }) }}",
                    type : 'POST',
                    data : data,
                    dataType: 'json',
                    cache: false,
                    success: function (response) {
                        let consomation_tmp=[];
                        let production_tmp=[];
                        let cedee_tmp=[];
                        let importe_tmp=[];
                        let auto_consome_tmp=[];
                        let year =0;
                        for (let i = 0; i < response.consomation.length ; i++) {
                            dates = new Date(response.production[i][0] * 1000);
                            year = dates.getFullYear();
                            consomation[0][i] = dates;
                            consomation[1][i] = response.consomation[i][1];
                            dates = new Date(response.production[i][0] * 1000);
                            dates.setFullYear(year);
                            production[0][i] = dates;
                            production[1][i] = response.production[i][1];
                            dates = new Date(response.auto_consomer[i][0] * 1000);
                            dates.setFullYear(year);
                            auto_consome[0][i]=dates;
                            auto_consome[1][i]=response.auto_consomer[i][1];
                            dates = new Date(response.cedee[i][0] * 1000);
                            dates.setFullYear(year);
                            cedee[0][i]=dates;
                            cedee[1][i]=response.cedee[i][1];
                            dates = new Date(response.importer[i][0] * 1000);
                            dates.setFullYear(year);
                            importer[0][i]=dates;
                            importer[1][i]=response.importer[i][1];
                            if(i>0 && (i%24)===0){
                                consomation_heatmap1.push(consomation_tmp);
                                production_heatmap1.push(production_tmp);
                                cedee_heatmap1.push(cedee_tmp);
                                importer_heatmap1.push(importe_tmp);
                                auto_consomer_heatmap1.push(auto_consome_tmp);
                                consomation_tmp=[];
                                production_tmp=[];
                                cedee_tmp=[];
                                importe_tmp=[];
                                auto_consome_tmp=[];
                                consomation_tmp.push(response.consomation[i][1]);
                                production_tmp.push(response.production[i][1]);
                                cedee_tmp.push(response.cedee[i][1]);
                                auto_consome_tmp.push(response.auto_consomer[i][1]);
                                importe_tmp.push(response.importer[i][1]);

                            }
                            else{
                                consomation_tmp.push(response.consomation[i][1]);
                                production_tmp.push(response.production[i][1]);
                                cedee_tmp.push(response.cedee[i][1]);
                                auto_consome_tmp.push(response.auto_consomer[i][1]);
                                importe_tmp.push(response.importer[i][1]);
                            }
                        }
                        consomation_heatmap=new transpose(consomation_heatmap1);
                        production_heatmap=new transpose(production_heatmap1);
                        cedee_heatmap=new transpose(cedee_heatmap1);
