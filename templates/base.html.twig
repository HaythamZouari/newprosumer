<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>
    {% block title %}
        Prosumers
    {% endblock %}
    </title>
    <link href={{ asset('build/img/brand/favicon.png') }} rel="icon" type="image/png">
    {% block stylesheet %}
    <!-- Favicon -->
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet">
    <!-- Icons -->
        <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css" integrity="sha384-ggOyR0iXCbMQv3Xipma34MD+dH/1fQ784/j6cY/iJTQUOhcWr7x9JvoRxT2MZw1T" crossorigin="anonymous">
    <link href={{ asset('build/js/plugins/nucleo/css/nucleo.css') }} rel="stylesheet" />
    <link href={{ asset('build/js/plugins/@fortawesome/fontawesome-free/css/all.min.css') }} rel="stylesheet" />
    <!-- CSS Files -->
    <link href={{ asset('build/css/argon-dashboard.css?v=1.1.0') }} rel="stylesheet" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/dygraph/2.1.0/dygraph.min.css" />
    <link type="text/css" rel="stylesheet" href="https://api.mqcdn.com/sdk/mapquest-js/v1.3.2/mapquest.css"/>
    {% endblock %}
</head>
<body  >
<div class="main-content">
    <!-- Navbar -->
    {% block navbartop %}
                <nav class="navbar navbar-top navbar-expand-md navbar-light" id="navbar-main">

                    <div class="container-fluid">
                        <!-- Toggler -->
                        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#sidenav-collapse-main" aria-controls="sidenav-main" aria-expanded="false" aria-label="Toggle navigation">
                            <span class="navbar-toggler-icon"></span>
                        </button>
                        <!-- Brand -->
                        <a class="navbar-brand pt-0 mr-6" href={{ path("dashboard") }}>
                            <img src="{{ asset('build/img/brand/blue.png') }}" class="navbar-brand-img em">
                        </a>
                        <!-- User -->
                        {% if app.user %}
                            <ul class="nav align-items-center d-md-none">
                                <li class="nav-item dropdown">
                                    <a class="nav-link" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <div class="media align-items-center">
                                        </div>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-arrow dropdown-menu-right">
                                        <div class=" dropdown-header noti-title">
                                            <h6 class="text-overflow m-0">Bienvenue!</h6>
                                        </div>
                                        <a href="./examples/profile.html" class="dropdown-item">
                                            <i class="ni ni-single-02"></i>
                                            <span>Mon profil</span>
                                        </a>
                                        <div class="dropdown-divider"></div>
                                        <a href="{{ path('security_logout') }}" class="dropdown-item">
                                            <i class="ni ni-user-run"></i>
                                            <span>Logout</span>
                                        </a>
                                    </div>
                                </li>
                            </ul>
                        {% endif %}
                        <!-- Collapse -->
                        <div class="collapse navbar-collapse" id="sidenav-collapse-main">
                            <!-- Collapse header -->
                            <div class="navbar-collapse-header d-md-none">
                                <div class="row">
                                    <div class="col-6 collapse-brand">
                                        <a href={{ path('security_login') }}>
                                            <img src="{{ asset('build/img/brand/blue.png') }}">
                                        </a>
                                    </div>
                                    <div class="col-6 collapse-close">
                                        <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#sidenav-collapse-main" aria-controls="sidenav-main" aria-expanded="false" aria-label="Toggle sidenav">
                                            <span></span>
                                            <span></span>
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <ul class="navbar-nav">
                                {#
                                <li class="nav-item active">
                                <a class=" nav-link active " href=" ./index.html"> <i class="ni ni-tv-2 "></i> Dashboard
                                </a>
                                </li>
                                #}
                                <li class="nav-item">
                                    <a class="nav-link " href="{{ path('project_index') }}">
                                        <i class="ni ni-folder-17 text-orange"></i>
                                        <span class="font-weight-bold text-gray">
                                        Projets
                                        </span>
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link " href="">
                                        <i class="ni ni-single-02 text-yellow"></i>
                                        <span class="font-weight-bold text-gray">
                                            Contactez nous
                                        </span>
                                    </a>
                                </li>
                                {% if not app.user %}
                                    <li class="nav-item  text-gray">
                                        <a class="nav-link" href="{{ path('security_login') }}">
                                            <i class="ni ni-key-25 text-info"></i>
                                            <span class="font-weight-bold text-gray">
                                                Connexion
                                            </span>
                                        </a>
                                    </li>
                                    <li class="nav-item text-gray">
                                        <a class="nav-link" href="{{ path('user_register') }}">
                                            <i class="ni ni-circle-08 text-pink"></i>
                                            <span class=" font-weight-bold text-gray">
                                            S'enregister
                                            </span>
                                        </a>
                                    </li>
                                {% else %}
                                    <li class="nav-item text-gray">
                                        <a class="nav-link" href="{{ path('security_logout') }}">
                                            <i class="ni ni-user-run text-red"></i>

                                            <span class="font-weight-bold text-gray">
                                            Déconnexion
                                            </span>
                                        </a>
                                    </li>
                                {% endif %}
                            </ul>
                            <!-- Divider -->
                            <hr class="my-3">
                            <!-- Heading -->
                            <!-- Navigation -->
                            {% if  app.user %}
                                <ul class="navbar-nav align-items-center d-none d-md-flex">
                                    <li class="nav-item dropdown">
                                        <a class="nav-link pr-0" href="#" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                            <div class="media align-items-center">
                                                <span class="avatar avatar-sm rounded-circle">
                                                  <img src={{ asset('build/img/brand/avatar.png')}}>
                                                </span>
                                                <div class="media-body ml-2 d-none d-lg-block">
                                                    <span class="mb-0 text-sm  font-weight-bold text-gray">{{ app.user }}</span>
                                                </div>
                                            </div>
                                        </a>
                                        <div class="dropdown-menu dropdown-menu-arrow dropdown-menu-right">
                                            {#
                                                <div class=" dropdown-header noti-title">
                                                    <h6 class="text-overflow m-0">Welcome!</h6>
                                                </div>
                                                <a href="./examples/profile.html" class="dropdown-item text-gray">
                                                    <i class="ni ni-single-02"></i>
                                                    <span>My profile</span>
                                                </a>
                                                <a href="./examples/profile.html" class="dropdown-item text-gray">
                                                    <i class="ni ni-settings-gear-65"></i>
                                                    <span>Settings</span>
                                                </a>
                                                <a href="./examples/profile.html" class="dropdown-item text-gray">
                                                    <i class="ni ni-calendar-grid-58"></i>
                                                    <span>Activity</span>
                                                </a>
                                                <a href="./examples/profile.html" class="dropdown-item text-gray">
                                                    <i class="ni ni-support-16"></i>
                                                    <span>Support</span>
                                                </a>
                                                #}
                                            <div class="dropdown-divider"></div>
                                            <a href="{{ path('security_logout') }}" class="dropdown-ite text-graym">
                                                <i class="ni ni-user-run"></i>
                                                <span>Logout</span>
                                            </a>
                                        </div>
                                    </li>
                                </ul>
                            {% endif %}
                        </div>
                    </div>
                </nav>
    {% endblock %}

    <!-- Header -->
    <div class="header bg-gradient-white pb-0 py-3 pt-5 pt-md-5">
        <div class="container-fluid">
            <div class="header-body">
                {% block header %}
                    <div class="row">

                       
                    </div>
                {% endblock %}
            </div>
        </div>
    </div>
    <div class="container-fluid mt-4">
        {% block body %}
        <div class="row">
            <div class="col-sm-1">
            </div>
            <div class="col-xl-10 mb-2 mb-sm-2">
                <img src="{{ asset('build/img/brand/Image8.png') }}" class="img-fluid" alt="Responsive image">
            </div>
        </div>
    </div>
    {% endblock %}
    {% block footer %}
        <!-- Footer -->
        <footer class="footer  card-footer">
            <div class="row align-items-center justify-content-xl-between">
                <div class="col-xl-6">
                    <div class="copyright text-center text-xl-left text-muted">
                        &copy; 2018 <a href="https://www.creative-tim.com" class="font-weight-bold ml-1" target="_blank">Creative Tim</a>
                    </div>
                </div>
                <div class="col-xl-6">
                    <ul class="nav nav-footer justify-content-center justify-content-xl-end">
                        <li class="nav-item">
                            <a href="https://www.creative-tim.com" class="nav-link" target="_blank">Creative Tim</a>
                        </li>
                        <li class="nav-item">
                            <a href="https://www.creative-tim.com/presentation" class="nav-link" target="_blank">About Us</a>
                        </li>
                        <li class="nav-item">
                            <a href="http://blog.creative-tim.com" class="nav-link" target="_blank">Blog</a>
                        </li>
                        <li class="nav-item">
                            <a href="https://github.com/creativetimofficial/argon-dashboard/blob/master/LICENSE.md" class="nav-link" target="_blank">MIT License</a>
                        </li>
                    </ul>
                </div>
            </div>
        </footer>
        {% endblock %}
    </div>
</div>
        {% block javascripts %}
            <!-- Global site tag (gtag.js) - Google Analytics -->
            <script async src="https://www.googletagmanager.com/gtag/js?id=UA-153153853-1"></script>
            <script>
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());

                gtag('config', 'UA-153141382-1');
            </script>
            {{ encore_entry_script_tags('app') }}

            <script src={{ asset('build/js/plugins/jquery/dist/jquery.min.js') }}></script>
            <script src={{ asset('build/js/plugins/chart.js/dist/Chart.min.js') }}></script>
            <script src={{ asset('build/js/plugins/chart.js/dist/Chart.extension.js') }}></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/dygraph/2.1.0/dygraph.min.js"></script>
            <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.11.0/umd/popper.min.js"></script>
            <script src={{ asset('build/js/argon-dashboard.min.js?v=1.1.0') }}></script>
            <script src="{{ asset('build/js/plotly-latest.min.js') }}"></script>
            <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js" integrity="sha384-JjSmVgyd0p3pXB1rRibZUAYoIIy6OrQ6VrjIEaFf/nJGzIxFDsf4x0xIM+B07jRM" crossorigin="anonymous"></script>
        {% endblock %}
    </body>
</html>
