    function financeSubmit() {

        {% if not app.user %}
        window.location.replace('{{ path('security_login') }}');
        {% else %}
        
         $('#loadingfin').show();
        var data = $('#financeForm').serialize();
        var url = $('#financeForm').attr('action');
        $.ajax({
            url: url,
            type : 'POST',
            data : data,
            dataType: 'json',
            cache: false,
            success: function (response) {
                
                    res();
                $('#successfin').show();
                 $('#loadingfin').hide();
                 $('#errorfin').hide();
                 document.getElementById('financeavancer').removeAttribute('disabled');
            },
            error: function (response) {
                 $('#errorfin').show();
                 $('#successfin').hide();
            }
        });
       
        return false;
        {% endif %}
    }
    function finavance(){

                $('#tabs-icons-text-4-tab').css("pointer-events"," visible");
                $('#tabs-icons-text-5-tab').css("pointer-events"," visible");
                $('#tabs-icons-text-3-tab').css("pointer-events"," none");
                
                $('#tabs-icons-text-3').toggle();
                $('#tabs-icons-text-4').toggle();
                $('#tabs-icons-text-4-tab').addClass('active');
                $('#tabs-icons-text-3-tab').removeClass('active');
                

    }
    function financeretour(){
                
                $('#tabs-icons-text-2-tab').css("pointer-events"," visible");
                $('#tabs-icons-text-3-tab').css("pointer-events"," none");
                $('#tabs-icons-text-3').toggle();
                $('#tabs-icons-text-2').toggle();
                $('#tabs-icons-text-2-tab').addClass('active');
                $('#tabs-icons-text-3-tab').removeClass('active');


    }

