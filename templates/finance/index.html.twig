<div class="card bg-secondary">
    <div class="card-header bg-transparent pb-5" ><button type="button" id="help" class="btn btn-primary"onclick="help()">Aide</button>
        
        <div class="card-body px-lg-5 py-lg-5">
            <form id="financeForm"  action="{{ path('finance',{'id':project.id}) }}" enctype="multipart/form-data" method="post">
                <div class="form-group ">
                
                    <label class="form-control-label required" for="capex">Coùt d'investissement Hors Taxes (DT)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le coùt d'investissement du projet en Hors Taxes">?</button>  
                    <div class="row">
                        <div class="col" >  
                            <input type="number" name="capex" id="capex" value="100000" min="0" class="form-control">
                            <div class="invalid-feedback" id="capexvalid">Ce coùt est trés élevé</div>
                        </div>DT
                        <div class="col">  
                            <input type="number"  id="capexpu" value="2500" min="0" class="form-control">
                        </div>/kWc
                    </div>

                </div>
                <div class="form-group">

                    <label class="form-control-label required" for="subvention">Subvention </label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le type de la subvention qui sera allouée au projet">?</button>
                </div>    
                <div class="row">
                    <div class="col">                 
                        <select class="form-control" id="typesub">
                            <option value=0>Sans subvention</option>
                            <option value=1>Subvention FTE</option>
                            <option value=2>Subvention Développement régional premier groupe</option>
                            <option value=3>Subvention Développement régional deuxiéme groupe</option>
                        </select>
                    </div>
                    <div class="col"> 
                        <input type="number" name="subvention" value="0" max="100" id="subvention" min="0" class="form-control">
                    </div>%
                    <div class="col">     
                        <input type="number"  value="0" max="100" id="subventionDT" min="0" class="form-control">
                    </div>DT
                 </div>      
                </div>
                <div class="row">
                    <div class="col">   
                        <div class="form-group">
                            <label class="form-control-label required" for="opex">Coùt d'opération et de maintenance (%)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le poucentage du coùt d'investissement qui sera alloué anuellement aux opérations et la maintenance (1% du coùt d'investiement pour un systéme fixe">?</button>
                            <input type="number" name="opex" id="opex" value="1" max="100" min="0" class="form-control">
                            <div class="invalid-feedback" id="opexvalid">Ce taux est élevé</div>
                        </div>
                    </div>
                    <div class="col">   
                        <div class="form-group">
                            <label class="form-control-label required" for="replinv">Coùt de remplacement des onduleurs (DT)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le coùt de remplacement des onduleurs aprés 15 ans (100DT par kWc selon des références ) ">?</button>
                            <input type="number" name="replinv" id="replinv" max="100" min="0" class="form-control">
                            <div class="invalid-feedback" id="replinvvalid">Ce coùt est élevé</div>
                        </div>
                    </div>
                    <div class="col">      
                        <div class="form-group">
                            <label class="form-control-label required" for="duree_proj">Durée de vie du projet (ans)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir la durée de vie du projet (25 ans pour les centrales PV)">?</button>
                            <input type="number" name="duree_proj" value="25" id=" " min="0" class="form-control">
                            <div class="invalid-feedback" id="duree_projvalid">Cette durée est longue</div>
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col">          
                        <div class="form-group">
                            <label class="form-control-label required" for="aug_tarif_v">Taux d'augmentation du tarif de vente de l'excédant (%)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le taux annuel de l'augmentation des tarif d'achat de l'excédant de la part de la STEG">?</button>
                            <input type="number" name="aug_tarif_v" id="aug_tarif_v" value="5"  max="100" min="0" class="form-control">
                            <div class="invalid-feedback" id="aug_tarif_vvalid">Ce taux est excessif</div>
                        </div>
                    </div>
                     <div class="col">      
                        <div class="form-group">
                            <label class="form-control-label required" for="aug_tarif_a">Taux d'augmentation du tarif d'achat de la STEG (%) </label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le Taux annuel d'augmentation des tarifs d'achat de l'électricité fournie par la STEG">?</button>
                            <input type="number" name="aug_tarif_a" id="aug_tarif_a" value="7" min="0"  max="100" class="form-control">
                            <div class="invalid-feedback" id="aug_tarif_avalid">Ce taux est excessif</div>
                        </div>
                    </div>
                    <div class="col">     
                        <div class="form-group">
                            <label class="form-control-label required" for="taux_actualisation">Taux d'actualisation annuel (%)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le taux d'actualisation pour les analyses des Cash flows">?</button>
                            <input type="number" name="taux_actualisation" value ="8" id="taux_actualisation" min="0"  max="100" class="form-control">
                            <div class="invalid-feedback" id="taux_actualisationvalid">Ce taux est excessif</div>
                        </div>
                    </div>
                </div>        
               

                <div class="form-group">
                   
                    <input type="checkbox" class="custom-control-input"  name="credit" id="credit">
                    <label class="custom-control-label" for="credit" >Crédit   </label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir s'il y'aura recours à un crédit pour le financement du projet">?</button>
                </div>    
                   
                <div id="credits_div" style="display: none">
                    <div class="row">
                        <div class="col">
                            <div class="form-group">
                                <label class="form-control-label required" for="dette">Montant de la dette (DT)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le montant total de  la dette">?</button>
                                <input type="number" name="dette" id="dette" min="0" class="form-control">
                                <div class="invalid-feedback" id="dettevalid">Ce montant de la dette est élevé</div>
                            </div>
                        </div>
                        <div class="col">

                            <div class="form-group">
                                <label class="form-control-label required" for="interet">Taux d'interet (%)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le taux d'intérét appliqué par la banque pour le calcul des annuités">?</button>
                                <input type="number" name="interet" value="11" id="interet" min="0"  max="100" class="form-control">
                                <div class="invalid-feedback" id="interetvalid">Ce taux est excessif</div>
                                
                            </div>
                        </div>
                    </div>    
                    <div class="row">
                        <div class="col">
                            <div class="form-group">
                                <label class="form-control-label required" for="delai_grace">Délai de gràce (ans)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir le nombre d'années de gràce s'il y en a sinon 0">?</button>
                                <input type="number" name="delai_grace"  value="0" id="delai_grace" min="0" class="form-control">
                                <div class="invalid-feedback" id="delai_gracevalid">Ce délai est long</div>
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-group">
                                <label class="form-control-label required" for="maturite_proj">Durée de remboursement [aprés délai de gràce] (ans)</label><button type="button" class="btn btn-primary btn-sm" data-container="body" data-toggle="popover" data-placement="right" data-content="Définir la durée de rempboursement de la dette aprés la période de gràce">?</button>
                                <input type="number" name="maturite_proj" value="7" id="maturite_proj" min="0" class="form-control">
                                <div class="invalid-feedback" id="maturite_projvalid">Cette durée est longue</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="text-center">
                    <div class="alert alert-success" id="successfin" role="alert" style="display:none"><strong>Finance Validée</strong> </div>
                    <div class="alert alert-danger" id="errorfin" role="alert" style="display:none"><strong>Finance non Valide</strong> </div>
                        <button type="button"  id="financeretour()"  onclick="financeretour()" class="btn-secondary btn">Retour</button>
                        <button type="button"  id="finance"  onclick="financeSubmit()" class="btn-secondary btn"><span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" id="loadingfin" style="display:none"></span>Valider</button>
                        <button type="button"  id="financeavancer" disabled="disabled" onclick="finavance()" class="btn-secondary btn">Continuer</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src={{ asset('build/js/plugins/jquery/dist/jquery.min.js') }}></script>
<script>

$("#opex").change(function() {
   if ($( "#opex" ).val()>5){
       $("#opexvalid").show();
   }
   else{
         $("#opexvalid").hide();

    }
});

$("#replinv").change(function() {
    if (($( "#peakpower" ).val())!=0){
