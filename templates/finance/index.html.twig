            $( "#subvention" ).val(15);
            $( "#subventionDT" ).val(($( "#capex" ).val())*0.15);
        }
        else{
         $( "#subvention" ).val(150000000/($( "#capex" ).val()));
            $( "#subventionDT" ).val(1500000);
        }
    }
     else
    if ($( "#typesub" ).val()==3){
        if ((($( "#capex" ).val())*0.3)<=3000000){
            $( "#subvention" ).val(30);
            $( "#subventionDT" ).val(($( "#capex" ).val())*0.3);
        }
        else{
         $( "#subvention" ).val(300000000/($( "#capex" ).val()));
            $( "#subventionDT" ).val(300000000);
        }
    }
});   
$("#capexpu").change(function() {
    if (($( "#peakpower" ).val())!=0){
        power=parseInt($( "#peakpower" ).val())+parseInt($( "#peakpower2" ).val())+parseInt($( "#peakpower3" ).val());
