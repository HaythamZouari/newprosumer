            $( "#subvention" ).val(20);
            $( "#subventionDT" ).val(($( "#capex" ).val())*0.2);
        }
        else{
         $( "#subvention" ).val(20000000/($( "#capex" ).val()));
            $( "#subventionDT" ).val(200000);
