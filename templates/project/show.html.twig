{% extends 'base.html.twig' %}
{% block title %}Project{% endblock %}
{% block navbar %}
{% endblock %}
{%  block header  %}
    <div class="nav-wrapper">
        <ul class="nav nav-pills nav-fill flex-column flex-md-row" id="tabs-icons-text" role="tablist">
            <li class="nav-item">
                <a class="nav-link mb-sm-3 mb-md-0 active" id="tabs-icons-text-1-tab" data-toggle="tab" href="#tabs-icons-text-1" role="tab" aria-controls="tabs-icons-text-1" aria-selected="true">Consomation</a>
            </li>
            <li class="nav-item">
               <a class="nav-link mb-sm-3 mb-md-0 " style="pointer-events: none;" id="tabs-icons-text-2-tab" data-toggle="tab" href="#tabs-icons-text-2" role="tab" aria-controls="tabs-icons-text-2" aria-selected="false">Production</a>
            </li>
            <li class="nav-item">
                <a class="nav-link mb-sm-3 mb-md-0" style="pointer-events: none;" id="tabs-icons-text-3-tab" data-toggle="tab" href="#tabs-icons-text-3" role="tab" aria-controls="tabs-icons-text-3" aria-selected="false">Finance</a>
            </li>
            <li class="nav-item">
                <a class="nav-link mb-sm-3 mb-md-0" style="pointer-events: none; "id="tabs-icons-text-4-tab" data-toggle="tab" href="#tabs-icons-text-4" role="tab" aria-controls="tabs-icons-text-4" aria-selected="false" >Resultats</a>
            </li>
            <li class="nav-item">
                <a class="nav-link mb-sm-3 mb-md-0" id="tabs-icons-text-5-tab" style="pointer-events: none; " href="{{ path('rapport',{'id':project.id}) }}" >Rapport</a>
            </li>
        </ul>
    </div>
{% endblock %}
{% block body %}
    <div class="container-fluid" >
        <div class="row">
            <div class="col-xl">
                <div class="card shadow">
                    <div class="card-body">
                        <div class="card" id="tabs-icons-text-1">
                            <div class="card-body">
                                {{ include('consomation/consomation.html.twig') }}
                            </div>
                        </div>
                        <div class="card" id="tabs-icons-text-2" style="display: none" >
                            <div class="card-body">
                                {{ include('production/production.html.twig') }}
                            </div>
                        </div>
                        <div class="card" id="tabs-icons-text-3" style="display: none">
                            <div class="card-body">
                                {{ include('finance/index.html.twig') }}
                            </div>
                        </div>
                        <div class="card" id="tabs-icons-text-4" style="display: none">
                            <div class="card-body">
                                {{ include('result/result.html.twig') }}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script>

        // init,configure dropzone
        function consomationSubmit() {
            {% if not app.user %}
            window.location.replace('{{ path('security_login') }}')
            {% endif %};
            var data = $('#consomationForm').serialize();
            var url = $('#consomationForm').attr('action');
            $.ajax({
                url: url,
                type : 'POST',
                data : data,
                dataType: 'json',
                cache: false,
                success: function (response) {
                    for (let i = 0; i < response.data.length ; i++) {
                        dates = new Date(response.data[i][0] * 1000);
                        dates.setHours(dates.getHours() - 1);
                        response.virgdata[i][0] = dates;
                    }
                    console.log(response.virgdata);
                    console.log(response.alpha);
                    console.log(response.beta);
                    console.log(response.gamma);
                    console.log(response.delta);
                    


                    $('#tabs-icons-text-2-tab').css("pointer-events"," visible");
                    $('#tabs-icons-text-1-tab').css("pointer-events"," none");
                    $('#tabs-icons-text-2-tab').addClass('active');
                    $('#tabs-icons-text-1-tab').removeClass('active');

                        $('#tabs-icons-text-2').toggle();
                        $('#tabs-icons-text-1').toggle();
                }
            });
            /*
            $.get( url ,data,function (dat) {
               console.log(dat);
            });
             */
            return false;
        }
    </script>
{% endblock %}
